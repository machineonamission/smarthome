[Container]
ContainerName=theengs
Image=docker.io/theengs/gateway:latest
PodmanArgs=--privileged
Volume=/run/dbus:/run/dbus:ro
Volume=/var/run/dbus:/var/run/dbus:ro
AutoUpdate=registry
Pull=newer
Environment=DBUS_SYSTEM_BUS_ADDRESS=unix:path=/run/dbus/system_bus_socket
Environment=MQTT_HOST=192.168.0.2
Environment=DISCOVERY=1
Environment=DISCOVERY_TOPIC=homeassistant/sensor

Pod=smarthome.pod

AddCapability=NET_ADMIN
AddCapability=NET_RAW
AddCapability=SYS_ADMIN

[Service]
Restart=always
