[Build]
ImageTag=localhost/gockai
SetWorkingDirectory=https://github.com/CYMKEight/GockAI

[Service]
# Only proceed with this build if the image is missing.
# If it exists, the shell exits with 1, which tells systemd to gracefully skip the build command.
ExecCondition=/bin/sh -c '/usr/bin/podman image exists localhost/gockai && exit 1 || exit 0'
