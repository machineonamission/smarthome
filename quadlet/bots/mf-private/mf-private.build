[Build]
ImageTag=localhost/mediaforge
SetWorkingDirectory=https://github.com/machineonamission/mediaforge.git
Environment=AUTOMODE=ON
BuildArg=AUTOMODE=ON

[Service]
Environment=HOME=/root
Environment=GIT_TERMINAL_PROMPT=0
# Only proceed with this build if the image is missing.
# If it exists, the shell exits with 1, which tells systemd to gracefully skip the build command.
ExecCondition=/bin/sh -c '/usr/bin/podman image exists localhost/mediaforge && exit 1 || exit 0'
