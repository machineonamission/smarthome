[Unit]
Wants=mf-private-build.service
After=mf-private-build.service

[Container]
Pod=bots.pod
ContainerName=mf-private
Image=ghcr.io/machineonamission/mediaforge:master
AutoUpdate=registry
Pull=newer
Volume=/srv/volumes/bot/mf-private/config.py:/mediaforge/config.py:z
Volume=/srv/volumes/bot/mf-private/database.db:/mediaforge/database.db:z
Environment=AUTOMODE=ON

[Service]
Restart=always
