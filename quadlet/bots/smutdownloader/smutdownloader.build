[Build]
ImageTag=localhost/smutdownloader
SetWorkingDirectory=https://github.com/machineonamission/smutdownloader

[Service]
# Only proceed with this build if the image is missing.
# If it exists, the shell exits with 1, which tells systemd to gracefully skip the build command.
ExecCondition=/bin/sh -c '/usr/bin/podman image exists localhost/smutdownloader && exit 1 || exit 0'
