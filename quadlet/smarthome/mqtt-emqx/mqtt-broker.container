[Container]
Pod=smarthome.pod
#Environment=EMQX_LOADED_PLUGINS="emqx_auth_username,emqx_management"
#Environment=EMQX_AUTH__USER__1__USERNAME=user
#Environment=EMQX_AUTH__USER__1__PASSWORD=password
Environment=EMQX_LISTENERS__TCP__DEFAULT__BIND=localhost:1883
Environment=EMQX_LISTENERS__SSL__DEFAULT__BIND="localhost:8883"
Environment=EMQX_LISTENERS__SSL__DEFAULT__SSL_OPTIONS__CERTFILE="/opt/emqx/etc/certs/client/fullchain1.pem"
Environment=EMQX_LISTENERS__SSL__DEFAULT__SSL_OPTIONS__KEYFILE="/opt/emqx/etc/certs/client/privkey1.pem"
Environment=EMQX_LISTENERS__SSL__DEFAULT__SSL_OPTIONS__CACERTFILE="/opt/emqx/etc/certs/client/chain1.pem"
Environment=EMQX_LISTENERS__WS__DEFAULT__BIND=localhost:8083
Environment=EMQX_LISTENERS__WSS__DEFAULT__BIND=localhost:8084
Environment=EMQX_LOG__CONSOLE__LEVEL=debug
Environment=EMQX_HOST=localhost
Environment=EMQX_TELEMETRY__ENABLE=false
Environment=EMQX_NODE__NAME=emqx@localhost
Image=docker.io/emqx/emqx:latest
Volume=emqx_config.volume:/opt/emqx/etc
Volume=emqx_log.volume:/opt/emqx/log
Volume=emqx_data.volume:/opt/emqx/data
ContainerName=mqtt-broker
